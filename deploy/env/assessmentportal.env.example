DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=assessment.example.com
DJANGO_STATIC_ROOT=/opt/assessmentportal/backend/staticfiles
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
FRONTEND_URL=https://assessment.example.com
CSRF_TRUSTED_ORIGINS=https://assessment.example.com

POSTGRES_HOST=replace.postgres.database.azure.com
POSTGRES_DB=assessment_portal
POSTGRES_USER=replace-managed-identity-database-role
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require

AZUREAD_AUTH_CLIENT_ID=replace-auth-app-client-id
AZUREAD_AUTH_CLIENT_SECRET=replace-auth-app-client-secret
AZUREAD_AUTH_TENANT_ID=replace-tenant-id

ZTA_MODULE_PATH=/opt/assessmentportal/modules/ZeroTrustAssessment
ZTA_RUNNER_SCRIPT=/opt/assessmentportal/backend/assessments/powershell/run_assessment.ps1
ZTA_OUTPUT_ROOT=/var/lib/assessmentportal/assessment-runs
ZTA_KEY_VAULT_URL=https://replace.vault.azure.net
# Optional. Used by the assessment runner only; portal Key Vault actions use system-assigned managed identity.
AZURE_CLIENT_ID=
